---
import styles from './Navbar.module.scss';
---

<header class={styles.navbar} id="navbar">
  <div class={`container ${styles.inner}`}>
    <a href="#hero" class={styles.logo}>
      <span class={styles.logoText}>NP<span class={styles.dot}>.</span></span>
    </a>

    <nav class={styles.nav}>
      <a href="#about"    class={styles.link}>About</a>
      <a href="#projects" class={styles.link}>Projects</a>
      <a href="#skills"   class={styles.link}>Skills</a>
      <a href="#contact"  class={styles.link}>Contact</a>
    </nav>

    <a
      href="https://github.com/neelpatel112"
      target="_blank"
      rel="noopener noreferrer"
      class={styles.cta}
    >
      GitHub ↗
    </a>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>